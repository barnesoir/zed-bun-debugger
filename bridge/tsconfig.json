{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "../../bin",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "bun-debug-adapter-protocol": ["../vendor/bun-debug-adapter-protocol/index.ts"],
      "bun-inspector-protocol": ["../vendor/bun-inspector-protocol/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
